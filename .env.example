# =========================================
# JAIMAARUTHI ELECTRICAL STORE - SERVER CONFIG
# =========================================

# ----------------
# Server Configuration
# ----------------
PORT=5000
NODE_ENV=development

# ----------------
# Database Configuration
# ----------------
MONGO_URI=mongodb://localhost:27017/jaimaaruthi_store

# ----------------
# JWT Authentication
# ----------------
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_complex
JWT_EXPIRE=7d

# ----------------
# Direct Payment Configuration (PRIMARY)
# ----------------
MERCHANT_UPI_ID=prannav2511@okhdfcbank
MERCHANT_NAME=Prannav P - Jaimaaruthi Electrical Store
BANK_NAME=Karur Vysya Bank
ACCOUNT_NUMBER=1054

# ----------------
# Razorpay Configuration (SECONDARY)
# ----------------
RAZORPAY_KEY_ID=rzp_live_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_PAYMENT_LINK=https://razorpay.me/@jaimaaruthi

# ----------------
# Email Configuration
# ----------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_store_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Jaimaaruthi Store <noreply@jaimaaruthi.com>

# ----------------
# WhatsApp Integration
# ----------------
WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_API_KEY=your_whatsapp_business_api_key
WHATSAPP_PHONE_NUMBER=+91XXXXXXXXXX

# ----------------
# File Upload Configuration
# ----------------
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpeg,jpg,png,webp,gif

# ----------------
# Security Configuration
# ----------------
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your_session_secret_key_here

# ----------------
# API Rate Limiting
# ----------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ----------------
# CORS Configuration
# ----------------
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ----------------
# Development/Debug Settings
# ----------------
DEBUG_MODE=true
LOG_LEVEL=info
ENABLE_DETAILED_LOGGING=true

# ----------------
# Analytics Configuration
# ----------------
ANALYTICS_REFRESH_INTERVAL=300000
ENABLE_REAL_TIME_ANALYTICS=true

# ----------------
# Notification Settings
# ----------------
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=true

# ----------------
# Payment Gateway Settings
# ----------------
PAYMENT_TIMEOUT=300000
ENABLE_PAYMENT_RETRY=true
MAX_PAYMENT_RETRIES=3

# ----------------
# Order Management
# ----------------
AUTO_STOCK_UPDATE=true
ORDER_EXPIRY_TIME=3600000
ENABLE_ORDER_TRACKING=true

# ----------------
# Cache Configuration
# ----------------
CACHE_TTL=3600
ENABLE_REDIS_CACHE=false
REDIS_URL=redis://localhost:6379

# ----------------
# Admin Configuration
# ----------------
ADMIN_EMAIL=admin@jaimaaruthi.com
ADMIN_PHONE=+91XXXXXXXXXX
STORE_NAME=Jaimaaruthi Electrical and Hardware Store